{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cc-collaboration/docs/handoff-package.schema.json",
  "title": "Handoff Package",
  "type": "object",
  "required": ["id", "schema_version", "sender", "recipient", "urgency", "created_at", "repo"],
  "properties": {
    "id":             {"type": "string", "pattern": "^h_[0-9]{8}_[A-Z0-9]+$"},
    "schema_version": {"type": "integer", "const": 1},
    "kind":           {"type": "string", "enum": ["", "delivery", "request", "bug", "capsule"], "description": "Direction/intent of the package. Empty (omitted) is treated as 'delivery' for backward compatibility with v0.1 payloads."},
    "sender":         {"type": "string"},
    "recipient":      {"type": "string"},
    "recipients":     {"type": "array", "items": {"type": "string"}},
    "urgency":        {"type": "string", "enum": ["normal", "urgent"]},
    "created_at":     {"type": "string", "format": "date-time"},
    "repo": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name":     {"type": "string"},
        "branch":   {"type": "string"},
        "head_sha": {"type": "string"},
        "base_sha": {"type": "string"}
      }
    },
    "summary_md": {"type": "string"},
    "git": {
      "type": "object",
      "properties": {
        "commits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sha", "subject"],
            "properties": {
              "sha":     {"type": "string"},
              "subject": {"type": "string"},
              "body":    {"type": "string"}
            }
          }
        },
        "diffstat":      {"type": "string"},
        "diff_unified":  {"type": "string"},
        "changed_paths": {"type": "array", "items": {"type": "string"}}
      }
    },
    "api_delta": {
      "type": "object",
      "required": ["format"],
      "properties": {
        "format":           {"type": "string"},
        "added":            {"type": "array", "items": {"$ref": "#/$defs/op"}},
        "changed":          {"type": "array", "items": {"$ref": "#/$defs/op"}},
        "removed":          {"type": "array", "items": {"$ref": "#/$defs/op"}},
        "raw_yaml_excerpt": {"type": "string"}
      }
    },
    "targeting_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "reason":         {"type": "string"},
          "matched_path":   {"type": "string"},
          "captures":       {"type": "object", "additionalProperties": {"type": "string"}},
          "suggest_edit":   {"type": "array", "items": {"type": "string"}},
          "suggest_create": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "delivery_target": {
      "type": "object",
      "description": "Original team-scoped delivery intent before project/org/member was expanded into concrete recipients.",
      "properties": {
        "project_id": {"type": "string"},
        "org_id":     {"type": "string"},
        "member":     {"type": "string"}
      }
    },
    "capsule": {
      "type": "object",
      "description": "Frozen agent context metadata. Team/project ids are optional for private capsules; new public capsules require an authorized organization or project scope.",
      "required": ["source_agent"],
      "properties": {
        "source_agent":      {"type": "string", "enum": ["claude", "codex"]},
        "origin_session_id": {"type": "string"},
        "visibility":        {"type": "string", "enum": ["private", "public"]},
        "org_id":            {"type": "string"},
        "project_id":        {"type": "string"},
        "has_transcript":    {"type": "boolean"},
        "has_persona":       {"type": "boolean"},
        "updated_at":        {"type": "string", "format": "date-time"}
      }
    },
    "note_md":     {"type": "string"},
    "prd_md":      {"type": "string"},
    "amends_handoff": {"type": "string"},
    "replaces_id": {"type": "string"},
    "responds_to": {"type": "string", "description": "When this package is a delivery answering a prior 'request' package, the original request id. The receiver-side prompt and summary.md render an '↩️ 回应' banner so the original requester can trace the loop. Should not be set on kind='request' packages."}
  },
  "$defs": {
    "op": {
      "type": "object",
      "required": ["method", "path"],
      "properties": {
        "method":       {"type": "string"},
        "path":         {"type": "string"},
        "operation_id": {"type": "string"},
        "summary":      {"type": "string"}
      }
    }
  }
}
