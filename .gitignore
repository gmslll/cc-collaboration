bin/
/build/
/dist/
*.exe
*.apk
*.test
*.out
# Android release signing (key.properties + cc-handoff-release.jks) is committed
# on purpose so CI signs with a stable key without secrets — see build.gradle.kts.
/cc-handoff
# Sibling root binaries from `make build` (cli/relay/mcp) — regenerable build
# artifacts, same as /cc-handoff above; never committed.
/relay
/mcp
# cc-handoff runtime state (materialized inbox, watch cursor, supervisor scaffold).
# The committed per-repo config is the .cc-handoff.toml file, not this directory.
.cc-handoff/
.DS_Store
.idea/
.vscode/
.toolchains/
relay.db
relay.db-journal
relay.db-wal
relay.db-shm
*.local.toml

# Stray launcher the paseo daemon drops into the cwd; not part of this repo.
/node-entrypoint-launcher.js

# Generated Flutter Web client bundle, embedded into the relay via //go:embed
# and regenerated by `make web`. The tracked .gitkeep keeps `//go:embed all:app`
# compilable on a fresh clone before the bundle is built.
/internal/relay/app/*
!/internal/relay/app/.gitkeep
